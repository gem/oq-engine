<?xml version="1.0" encoding="utf-8"?>
<nrml xmlns="http://openquake.org/xmlns/nrml/0.5" xmlns:gml="http://www.opengis.net/gml">
    <logicTree logicTreeID="lt">

        <logicTreeBranchSet branchSetID="bs0" uncertaintyType="sourceModel">
            <logicTreeBranch branchID="alt12">
                <!-- Alt1 (area sources with TE or AC MFD) + Alt2 (with embedded faults and area sources, using incrementalMFD to split rates) -->
                <uncertaintyModel>alt12.xml</uncertaintyModel>
                <uncertaintyWeight>0.5</uncertaintyWeight>
            </logicTreeBranch>

            <logicTreeBranch branchID="alt3">
                <!-- Alt3 (embedded faults and area sources with total EQ rate partioned using seismic moment) -->
                <uncertaintyModel>alt3.xml</uncertaintyModel>
                <uncertaintyWeight>0.5</uncertaintyWeight>
            </logicTreeBranch>
        </logicTreeBranchSet>

        <!-- Apply only to NVA-UBN (alt_bound=west, unc_bound=north) geometry version of the area source; TE (0.7) vs AC (0.3) as alternative MFD flavours -->
        <logicTreeBranchSet applyToSources="NVA-UBN-bkg" branchSetID="bs1a" uncertaintyType="recurSet">
            <logicTreeBranch branchID="262">
                <!-- TE MFD for NVA-UBN geometry -->
                <uncertaintyModel><row recur_model="TE" alt_bound="west" unc_bound="north" max_mag="6.8"/></uncertaintyModel>
                <uncertaintyWeight>0.7</uncertaintyWeight>
            </logicTreeBranch>

            <logicTreeBranch branchID="70">
                <!-- AC MFD for NVA-UBN geometry -->
                <uncertaintyModel><row recur_model="AC" alt_bound="west" unc_bound="north" max_mag="6.8"/></uncertaintyModel>
                <uncertaintyWeight>0.3</uncertaintyWeight>
            </logicTreeBranch>
        </logicTreeBranchSet>

        <!-- applyToSources must be used to target only required sources in given recurSet -->
        <logicTreeBranchSet applyToBranches="262" applyToSources="NVA-UBN-bkg" branchSetID="bs2a" uncertaintyType="recurRow">
            <logicTreeBranch branchID="262a">
                <uncertaintyModel><row b_value="0.531" ref_mag="3.25" rate="0.223505"/></uncertaintyModel>
                <uncertaintyWeight>0.7</uncertaintyWeight>
            </logicTreeBranch>

            <logicTreeBranch branchID="262b">
                <uncertaintyModel><row b_value="0.666" ref_mag="3.25" rate="0.223505"/></uncertaintyModel>
                <uncertaintyWeight>0.3</uncertaintyWeight>
            </logicTreeBranch>
        </logicTreeBranchSet>

        <!-- applyToSources must be used to target only required sources in given recurSet -->
        <logicTreeBranchSet applyToBranches="70" applyToSources="NVA-UBN-bkg" branchSetID="bs2b" uncertaintyType="recurRow">
            <logicTreeBranch branchID="70a">
                <uncertaintyModel><row b_value="0.536" ref_mag="3.25" rate="0.227421"/></uncertaintyModel>
                <uncertaintyWeight>0.7</uncertaintyWeight>
            </logicTreeBranch>

            <logicTreeBranch branchID="70b">
                <uncertaintyModel><row b_value="0.674" ref_mag="3.25" rate="0.224412"/></uncertaintyModel>
                <uncertaintyWeight>0.3</uncertaintyWeight>
            </logicTreeBranch>
        </logicTreeBranchSet>

        <!-- Apply only to NVA-AB (alt_bound=east, unc_bound=central) geometry version of the area source; TE (0.7) vs AC (0.3) as alternative MFD flavours -->
        <logicTreeBranchSet applyToSources="NVA-AB-bkg" branchSetID="bs1b" uncertaintyType="recurSet">
            <logicTreeBranch branchID="154">
                <!-- TE MFD for NVA-AB geometry -->
                <uncertaintyModel><row recur_model="TE" alt_bound="east" unc_bound="central" max_mag="6.8"/></uncertaintyModel>
                <uncertaintyWeight>0.7</uncertaintyWeight>
            </logicTreeBranch>

            <logicTreeBranch branchID="52">
                <!-- AC MFD for NVA-AB geometry -->
                <uncertaintyModel><row recur_model="AC" alt_bound="east" unc_bound="central" max_mag="6.8"/></uncertaintyModel>
                <uncertaintyWeight>0.3</uncertaintyWeight>
            </logicTreeBranch>
        </logicTreeBranchSet>

        <!-- applyToSources must be used to target only required sources in given recurSet -->
        <logicTreeBranchSet applyToBranches="154" applyToSources="NVA-AB-bkg" branchSetID="bs2c" uncertaintyType="recurRow">
            <logicTreeBranch branchID="154a">
                <uncertaintyModel><row b_value="0.567" ref_mag="3.25" rate="0.119375"/></uncertaintyModel>
                <uncertaintyWeight>0.7</uncertaintyWeight>
            </logicTreeBranch>

            <logicTreeBranch branchID="154b">
                <uncertaintyModel><row b_value="0.724" ref_mag="3.25" rate="0.119375"/></uncertaintyModel>
                <uncertaintyWeight>0.3</uncertaintyWeight>
            </logicTreeBranch>
        </logicTreeBranchSet>

        <!-- applyToSources must be used to target only required sources in given recurSet -->
        <logicTreeBranchSet applyToBranches="52" applyToSources="NVA-AB-bkg" branchSetID="bs2d" uncertaintyType="recurRow">
            <logicTreeBranch branchID="52a">
                <uncertaintyModel><row b_value="0.575" ref_mag="3.25" rate="0.121338"/></uncertaintyModel>
                <uncertaintyWeight>0.7</uncertaintyWeight>
            </logicTreeBranch>

            <logicTreeBranch branchID="52b">
                <uncertaintyModel><row b_value="0.735" ref_mag="3.25" rate="0.119743"/></uncertaintyModel>
                <uncertaintyWeight>0.3</uncertaintyWeight>
            </logicTreeBranch>
        </logicTreeBranchSet>

        <!-- Lower seismogenic depth epistemic uncertainty: correlated across both area source geometries so the same LSD is used for both in each realization -->
        <logicTreeBranchSet applyToSources="*" branchSetID="bs3" uncertaintyType="setLowerSeismDepthAbsolute">
            <logicTreeBranch branchID="lsd10">
                <uncertaintyModel>
                    <correlated src="NVA-UBN-bkg">10.0</correlated>
                    <correlated src="NVA-AB-bkg">10.0</correlated>
                </uncertaintyModel>
                <uncertaintyWeight>0.3</uncertaintyWeight>
            </logicTreeBranch>

            <logicTreeBranch branchID="lsd15">
                <uncertaintyModel>
                    <correlated src="NVA-UBN-bkg">15.0</correlated>
                    <correlated src="NVA-AB-bkg">15.0</correlated>
                </uncertaintyModel>
                <uncertaintyWeight>0.4</uncertaintyWeight>
            </logicTreeBranch>

            <logicTreeBranch branchID="lsd20">
                <uncertaintyModel>
                    <correlated src="NVA-UBN-bkg">20.0</correlated>
                    <correlated src="NVA-AB-bkg">20.0</correlated>
                </uncertaintyModel>
                <uncertaintyWeight>0.3</uncertaintyWeight>
            </logicTreeBranch>
        </logicTreeBranchSet>

