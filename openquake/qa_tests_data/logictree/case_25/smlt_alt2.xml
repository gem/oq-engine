<?xml version="1.0" encoding="utf-8"?>
<nrml xmlns="http://openquake.org/xmlns/nrml/0.5" xmlns:gml="http://www.opengis.net/gml">
    <logicTree logicTreeID="lt_alt2">

        <!-- 2 alt2 geometries: bg area + same 4 embedded faults each, but with distinct IDs. -->
        <logicTreeBranchSet branchSetID="bs_sm" uncertaintyType="sourceModel">
            <logicTreeBranch branchID="alt2_west">
                <uncertaintyModel>alt2_west.xml</uncertaintyModel>
                <uncertaintyWeight>0.5</uncertaintyWeight>
            </logicTreeBranch>
            <logicTreeBranch branchID="alt2_east">
                <uncertaintyModel>alt2_east.xml</uncertaintyModel>
                <uncertaintyWeight>0.5</uncertaintyWeight>
            </logicTreeBranch>
        </logicTreeBranchSet>

        <!-- recurSet (correlated across bg + 4 faults): TE (b variable) and AC (piecewise) -->
        <logicTreeBranchSet applyToBranches="alt2_west" applyToSources="alt2w-bkg alt2w-EF1 alt2w-EF2 alt2w-EF3 alt2w-EF4" branchSetID="bs_rs_w" uncertaintyType="recurSet">
            <logicTreeBranch branchID="te_w">
                <uncertaintyModel><row recur_model="TE" alt_bound="west" unc_bound="north" max_mag="7.0"/></uncertaintyModel>
                <uncertaintyWeight>0.7</uncertaintyWeight>
            </logicTreeBranch>
            <logicTreeBranch branchID="ac_w">
                <uncertaintyModel><row recur_model="AC" alt_bound="west" unc_bound="north" max_mag="7.0"/></uncertaintyModel>
                <uncertaintyWeight>0.3</uncertaintyWeight>
            </logicTreeBranch>
        </logicTreeBranchSet>

        <logicTreeBranchSet applyToBranches="alt2_east" applyToSources="alt2e-bkg alt2e-EF1 alt2e-EF2 alt2e-EF3 alt2e-EF4" branchSetID="bs_rs_e" uncertaintyType="recurSet">
            <logicTreeBranch branchID="te_e">
                <uncertaintyModel><row recur_model="TE" alt_bound="east" unc_bound="central" max_mag="7.0"/></uncertaintyModel>
                <uncertaintyWeight>0.7</uncertaintyWeight>
            </logicTreeBranch>
            <logicTreeBranch branchID="ac_e">
                <uncertaintyModel><row recur_model="AC" alt_bound="east" unc_bound="central" max_mag="7.0"/></uncertaintyModel>
                <uncertaintyWeight>0.3</uncertaintyWeight>
            </logicTreeBranch>
        </logicTreeBranchSet>

        <!-- rateSplit (correlated across bg + faults): scenario 1 (5/95) vs scenario 2 (15/85). One branchset per recurSet branch. -->
        <logicTreeBranchSet applyToBranches="te_w" applyToSources="alt2w-bkg alt2w-EF1 alt2w-EF2 alt2w-EF3 alt2w-EF4" branchSetID="bs_rspl_te_w" uncertaintyType="rateSplit">
            <logicTreeBranch branchID="scn1_te_w">
                <uncertaintyModel><row bg_frac="0.05" fault_frac="0.95"/></uncertaintyModel>
                <uncertaintyWeight>0.5</uncertaintyWeight>
            </logicTreeBranch>
            <logicTreeBranch branchID="scn2_te_w">
                <uncertaintyModel><row bg_frac="0.15" fault_frac="0.85"/></uncertaintyModel>
                <uncertaintyWeight>0.5</uncertaintyWeight>
            </logicTreeBranch>
        </logicTreeBranchSet>

        <logicTreeBranchSet applyToBranches="ac_w" applyToSources="alt2w-bkg alt2w-EF1 alt2w-EF2 alt2w-EF3 alt2w-EF4" branchSetID="bs_rspl_ac_w" uncertaintyType="rateSplit">
            <logicTreeBranch branchID="scn1_ac_w">
                <uncertaintyModel><row bg_frac="0.05" fault_frac="0.95"/></uncertaintyModel>
                <uncertaintyWeight>0.5</uncertaintyWeight>
            </logicTreeBranch>
            <logicTreeBranch branchID="scn2_ac_w">
                <uncertaintyModel><row bg_frac="0.15" fault_frac="0.85"/></uncertaintyModel>
                <uncertaintyWeight>0.5</uncertaintyWeight>
            </logicTreeBranch>
        </logicTreeBranchSet>

        <logicTreeBranchSet applyToBranches="te_e" applyToSources="alt2e-bkg alt2e-EF1 alt2e-EF2 alt2e-EF3 alt2e-EF4" branchSetID="bs_rspl_te_e" uncertaintyType="rateSplit">
            <logicTreeBranch branchID="scn1_te_e">
                <uncertaintyModel><row bg_frac="0.05" fault_frac="0.95"/></uncertaintyModel>
                <uncertaintyWeight>0.5</uncertaintyWeight>
            </logicTreeBranch>
            <logicTreeBranch branchID="scn2_te_e">
                <uncertaintyModel><row bg_frac="0.15" fault_frac="0.85"/></uncertaintyModel>
                <uncertaintyWeight>0.5</uncertaintyWeight>
            </logicTreeBranch>
        </logicTreeBranchSet>

        <logicTreeBranchSet applyToBranches="ac_e" applyToSources="alt2e-bkg alt2e-EF1 alt2e-EF2 alt2e-EF3 alt2e-EF4" branchSetID="bs_rspl_ac_e" uncertaintyType="rateSplit">
            <logicTreeBranch branchID="scn1_ac_e">
                <uncertaintyModel><row bg_frac="0.05" fault_frac="0.95"/></uncertaintyModel>
                <uncertaintyWeight>0.5</uncertaintyWeight>
            </logicTreeBranch>
            <logicTreeBranch branchID="scn2_ac_e">
                <uncertaintyModel><row bg_frac="0.15" fault_frac="0.85"/></uncertaintyModel>
                <uncertaintyWeight>0.5</uncertaintyWeight>
            </logicTreeBranch>
        </logicTreeBranchSet>

        <!-- recurRow (single branch per rateSplit): drives the piecewise MFD construction on all 5 correlated sources. -->
        <logicTreeBranchSet applyToBranches="scn1_te_w" applyToSources="alt2w-bkg alt2w-EF1 alt2w-EF2 alt2w-EF3 alt2w-EF4" branchSetID="bs_rr_scn1_te_w" uncertaintyType="recurRow">
            <logicTreeBranch branchID="row_scn1_te_w">
                <uncertaintyModel><row b_value="0.6" ref_mag="3.25" rate="0.2"/></uncertaintyModel>
                <uncertaintyWeight>1.0</uncertaintyWeight>
            </logicTreeBranch>
        </logicTreeBranchSet>

        <logicTreeBranchSet applyToBranches="scn2_te_w" applyToSources="alt2w-bkg alt2w-EF1 alt2w-EF2 alt2w-EF3 alt2w-EF4" branchSetID="bs_rr_scn2_te_w" uncertaintyType="recurRow">
            <logicTreeBranch branchID="row_scn2_te_w">
                <uncertaintyModel><row b_value="0.6" ref_mag="3.25" rate="0.2"/></uncertaintyModel>
                <uncertaintyWeight>1.0</uncertaintyWeight>
            </logicTreeBranch>
        </logicTreeBranchSet>

        <logicTreeBranchSet applyToBranches="scn1_ac_w" applyToSources="alt2w-bkg alt2w-EF1 alt2w-EF2 alt2w-EF3 alt2w-EF4" branchSetID="bs_rr_scn1_ac_w" uncertaintyType="recurRow">
            <logicTreeBranch branchID="row_scn1_ac_w">
                <uncertaintyModel><row b_value="0.6" ref_mag="3.25" rate="0.2"/></uncertaintyModel>
                <uncertaintyWeight>1.0</uncertaintyWeight>
            </logicTreeBranch>
        </logicTreeBranchSet>

        <logicTreeBranchSet applyToBranches="scn2_ac_w" applyToSources="alt2w-bkg alt2w-EF1 alt2w-EF2 alt2w-EF3 alt2w-EF4" branchSetID="bs_rr_scn2_ac_w" uncertaintyType="recurRow">
            <logicTreeBranch branchID="row_scn2_ac_w">
                <uncertaintyModel><row b_value="0.6" ref_mag="3.25" rate="0.2"/></uncertaintyModel>
                <uncertaintyWeight>1.0</uncertaintyWeight>
            </logicTreeBranch>
        </logicTreeBranchSet>

        <logicTreeBranchSet applyToBranches="scn1_te_e" applyToSources="alt2e-bkg alt2e-EF1 alt2e-EF2 alt2e-EF3 alt2e-EF4" branchSetID="bs_rr_scn1_te_e" uncertaintyType="recurRow">
            <logicTreeBranch branchID="row_scn1_te_e">
                <uncertaintyModel><row b_value="0.6" ref_mag="3.25" rate="0.2"/></uncertaintyModel>
                <uncertaintyWeight>1.0</uncertaintyWeight>
            </logicTreeBranch>
        </logicTreeBranchSet>

        <logicTreeBranchSet applyToBranches="scn2_te_e" applyToSources="alt2e-bkg alt2e-EF1 alt2e-EF2 alt2e-EF3 alt2e-EF4" branchSetID="bs_rr_scn2_te_e" uncertaintyType="recurRow">
            <logicTreeBranch branchID="row_scn2_te_e">
                <uncertaintyModel><row b_value="0.6" ref_mag="3.25" rate="0.2"/></uncertaintyModel>
                <uncertaintyWeight>1.0</uncertaintyWeight>
            </logicTreeBranch>
        </logicTreeBranchSet>

        <logicTreeBranchSet applyToBranches="scn1_ac_e" applyToSources="alt2e-bkg alt2e-EF1 alt2e-EF2 alt2e-EF3 alt2e-EF4" branchSetID="bs_rr_scn1_ac_e" uncertaintyType="recurRow">
            <logicTreeBranch branchID="row_scn1_ac_e">
                <uncertaintyModel><row b_value="0.6" ref_mag="3.25" rate="0.2"/></uncertaintyModel>
                <uncertaintyWeight>1.0</uncertaintyWeight>
            </logicTreeBranch>
        </logicTreeBranchSet>

        <logicTreeBranchSet applyToBranches="scn2_ac_e" applyToSources="alt2e-bkg alt2e-EF1 alt2e-EF2 alt2e-EF3 alt2e-EF4" branchSetID="bs_rr_scn2_ac_e" uncertaintyType="recurRow">
            <logicTreeBranch branchID="row_scn2_ac_e">
                <uncertaintyModel><row b_value="0.6" ref_mag="3.25" rate="0.2"/></uncertaintyModel>
                <uncertaintyWeight>1.0</uncertaintyWeight>
            </logicTreeBranch>
        </logicTreeBranchSet>

        <!-- Fault dip epistemic (correlated across all 4 faults per sm via applyToSources) -->
        <logicTreeBranchSet applyToBranches="row_scn1_te_w row_scn2_te_w row_scn1_ac_w row_scn2_ac_w row_scn1_te_e row_scn2_te_e row_scn1_ac_e row_scn2_ac_e" applyToSources="alt2w-EF1 alt2w-EF2 alt2w-EF3 alt2w-EF4 alt2e-EF1 alt2e-EF2 alt2e-EF3 alt2e-EF4" branchSetID="bs_dip" uncertaintyType="simpleFaultDipAbsolute">
            <logicTreeBranch branchID="dip45">
                <uncertaintyModel>45.0</uncertaintyModel>
                <uncertaintyWeight>0.5</uncertaintyWeight>
            </logicTreeBranch>
            <logicTreeBranch branchID="dip60">
                <uncertaintyModel>60.0</uncertaintyModel>
                <uncertaintyWeight>0.5</uncertaintyWeight>
            </logicTreeBranch>
        </logicTreeBranchSet>

        <!-- LSD applied to the bg area sources only (faults keep their fixed geometry LSD). Chained after the dip branchset since each branch can only be parent to one child branchset. -->
        <logicTreeBranchSet applyToBranches="dip45 dip60" applyToSources="alt2w-bkg alt2e-bkg" branchSetID="bs_lsd" uncertaintyType="setLowerSeismDepthAbsolute">
            <logicTreeBranch branchID="lsd15">
                <uncertaintyModel>15.0</uncertaintyModel>
                <uncertaintyWeight>1.0</uncertaintyWeight>
            </logicTreeBranch>
        </logicTreeBranchSet>

    </logicTree>
</nrml>
