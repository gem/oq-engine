<?xml version="1.0" encoding="UTF-8"?>

<nrml xmlns:gml="http://www.opengis.net/gml"
      xmlns="http://openquake.org/xmlns/nrml/0.4">
  <logicTree logicTreeID='lt1'>
    <logicTreeBranchSet uncertaintyType="gmpeModel" branchSetID="TabularMixtureModel"
                        applyToTectonicRegionType="Stable Crustal">

      <logicTreeBranch branchID="b1">
        <uncertaintyModel>
          [NGAEastUSGSGMPE]
          gmpe_table = 'nga_east_usgs_8.hdf5' <!-- Specify a tabular GMM in a mixture model --> 
          sigma_model="PANEL" 
          [NGAEastUSGSGMPE.mixture_model]                  
          factors = [0.8, 1.2]
          weights = [0.5, 0.5]
        </uncertaintyModel>                   
        <uncertaintyWeight>0.3</uncertaintyWeight>
      </logicTreeBranch>     

      <logicTreeBranch branchID="b2">
        <uncertaintyModel>
          [ChiouYoungs2014.mixture_model] <!-- Simplest way to define a non-tabular mixture model -->                  
          factors = [0.8, 1.2]
          weights = [0.5, 0.5]
        </uncertaintyModel>                   
        <uncertaintyWeight>0.3</uncertaintyWeight>
      </logicTreeBranch>     

      <logicTreeBranch branchID="b3">
        <uncertaintyModel>
          [ChiouYoungs2014]
          region = "JPN" <!-- Specify a non-tabular GMM with additional params in a mixture model --> 
          [ChiouYoungs2014.mixture_model]                  
          factors = [0.8, 1.2]
          weights = [0.5, 0.5]
        </uncertaintyModel>                   
        <uncertaintyWeight>0.4</uncertaintyWeight>
      </logicTreeBranch>     
    
    </logicTreeBranchSet>
  </logicTree>
</nrml>
